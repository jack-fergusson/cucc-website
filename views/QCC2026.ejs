<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Queen's Chess Championship 2026 – Queen's Chess Club</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Vollkorn:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@100;200;300;400;500;600&display=swap" rel="stylesheet">
    <link href="css/styles.css" rel="stylesheet">
    <link href="css/tournament-page.css" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.1/css/all.min.css">
    <link rel="shortcut icon" type="image/x-icon" href="images/logo.jpg"/>

    <style>
        .qcc-registration-card {
            background: linear-gradient(135deg, #2d2926 0%, #1a1614 100%);
            border-radius: 14px;
            padding: 36px 40px;
            color: white;
            margin-bottom: 32px;
            position: relative;
            overflow: hidden;
        }

        .qcc-registration-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 4px;
            background: linear-gradient(90deg, #c84b31, #ffcc29, #c84b31);
        }

        .qcc-registration-card h3 {
            font-family: 'League Spartan', sans-serif;
            font-size: 1.3rem;
            font-weight: 600;
            color: #ffcc29;
            margin: 0 0 10px 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .qcc-registration-card p {
            font-family: 'Vollkorn', serif;
            font-size: 1.05rem;
            color: #d4cfc9;
            margin: 0 0 24px 0;
            line-height: 1.7;
        }

        .qcc-register-btn {
            display: inline-block;
            background: #c84b31;
            color: white;
            font-family: 'League Spartan', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            padding: 13px 32px;
            border-radius: 8px;
            text-decoration: none;
            letter-spacing: 0.5px;
            transition: background 0.2s ease, transform 0.2s ease;
        }

        .qcc-register-btn:hover {
            background: #a83928;
            transform: translateY(-2px);
            color: white;
            text-decoration: none;
        }

        .early-bird-badge {
            display: inline-block;
            background: #ffcc29;
            color: #2d2926;
            font-family: 'League Spartan', sans-serif;
            font-size: 0.82rem;
            font-weight: 700;
            padding: 5px 14px;
            border-radius: 20px;
            margin-left: 12px;
            vertical-align: middle;
            letter-spacing: 0.5px;
        }

        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-top: 24px;
        }

        .pricing-card {
            background: white;
            border-radius: 12px;
            padding: 28px 26px;
            box-shadow: 0 4px 16px rgba(0,0,0,0.07);
            border-top: 4px solid #c84b31;
            text-align: center;
        }

        .pricing-card.crown {
            border-top-color: #ffcc29;
        }

        .pricing-card .section-label {
            font-family: 'League Spartan', sans-serif;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #999;
            margin-bottom: 6px;
        }

        .pricing-card .section-name {
            font-family: 'Vollkorn', serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: #2d2926;
            margin-bottom: 16px;
        }

        .pricing-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid #f0ece8;
            font-size: 0.95rem;
            color: #555;
            font-family: 'Vollkorn', serif;
        }

        .pricing-row:last-child {
            border-bottom: none;
        }

        .pricing-row .price {
            font-weight: 700;
            color: #2d2926;
        }

        .pricing-row .early-label {
            color: #c84b31;
            font-size: 0.82rem;
            font-style: italic;
        }

        .prize-amount {
            font-family: 'Vollkorn', serif;
            font-size: 2.4rem;
            font-weight: 700;
            color: #c84b31;
            line-height: 1;
            margin-bottom: 4px;
        }

        .pricing-card.crown .prize-amount {
            color: #b8960a;
        }

        .prize-label {
            font-size: 0.82rem;
            color: #999;
            font-family: 'League Spartan', sans-serif;
            letter-spacing: 0.5px;
            margin-bottom: 16px;
        }

        .countdown-strip {
            background: #fff8e6;
            border: 1px solid #ffe599;
            border-radius: 10px;
            padding: 16px 22px;
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 28px;
        }

        .countdown-strip i {
            font-size: 1.4rem;
            color: #c84b31;
        }

        .countdown-strip p {
            margin: 0;
            font-family: 'Vollkorn', serif;
            font-size: 1rem;
            color: #5a4a2a;
            line-height: 1.5;
        }

        .countdown-strip strong {
            color: #c84b31;
        }
    </style>
</head>

<%- include('header.ejs') %>

<body>
    <!-- Hero Banner -->
    <div class="tournament-hero" style="background-image: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.68)), url('images/stauffer.jpg'); background-size: cover; background-position: center center;">
        <div class="tournament-hero-overlay" style="background: none;">
            <div class="tournament-hero-content">
                <h1 style="color: white;">Queen's Chess Championship 2026</h1>
                <div class="tournament-date-badge">March 28–29, 2026 &middot; Kingston, ON</div>
                <p class="tournament-tagline">Queen's annual CFC-rated classical championship</p>
            </div>
        </div>
    </div>

    <div class="centerer">
        <div class="tournament-container" style="margin-top: 40px; margin-bottom: 60px;">

            <!-- Early Bird Alert -->
            <div class="countdown-strip">
                <i class="fas fa-fire"></i>
                <p><strong>Early Bird Registration ends March 20th!</strong> Register before March 20th to lock in the $40 entry fee — regular pricing is $50.</p>
            </div>

            <!-- Quick Info Panel -->
            <div class="tournament-info-panel">
                <div class="tournament-info-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <div class="tournament-info-content">
                        <h3>Location</h3>
                        <p>Stauffer Library, Room 014<br>Queen's University, Kingston</p>
                    </div>
                </div>
                <div class="tournament-info-item">
                    <i class="far fa-calendar-alt"></i>
                    <div class="tournament-info-content">
                        <h3>Dates</h3>
                        <p>Saturday March 28th &amp;<br>Sunday March 29th, 2026</p>
                    </div>
                </div>
                <div class="tournament-info-item">
                    <i class="fas fa-chess-knight"></i>
                    <div class="tournament-info-content">
                        <h3>Format</h3>
                        <p>5 rounds · Swiss · 90+30<br>CFC-Rated</p>
                    </div>
                </div>
                <div class="tournament-info-item">
                    <i class="fas fa-clock"></i>
                    <div class="tournament-info-content">
                        <h3>Start Time</h3>
                        <p>10:00 AM both days</p>
                    </div>
                </div>
            </div>

            <!-- Registration Card -->
            <div class="qcc-registration-card">
                <h3>Register Now <span class="early-bird-badge">Early Bird Open</span></h3>
                <p>Register via the link in our Instagram bio or reach out directly. Early bird pricing of $40 is available until <strong>March 20th</strong> — after that the entry fee rises to $50.</p>
                <a href="https://www.instagram.com/queenschessclub/" target="_blank" class="qcc-register-btn">
                    <i class="fab fa-instagram" style="margin-right: 8px;"></i>Register via Instagram
                </a>
            </div>

            <!-- About Section -->
            <div class="tournament-section">
                <h2>About the Tournament</h2>
                <p>The Queen's Chess Championship is the premier classical chess event hosted by the Queen's Chess Club, bringing together players from Queen's University and the broader Kingston community.</p>
                <p>This CFC-rated tournament runs over two days with two competitive sections — the <strong>Crown</strong> section for stronger players and the <strong>U1600</strong> section for developing players. All players must have a CFC membership to participate.</p>
                <p>With cash prizes on offer and five hard-fought rounds under classical time controls, QCC 2026 promises to be the most competitive edition yet.</p>
            </div>

            <!-- Pricing & Prizes -->
            <div class="tournament-section">
                <h2>Sections &amp; Prizes</h2>
                <div class="pricing-grid">
                    <div class="pricing-card">
                        <div class="section-label">Section</div>
                        <div class="section-name">U1600</div>
                        <div class="prize-amount">$100</div>
                        <div class="prize-label">PRIZE POOL</div>
                        <div class="pricing-row">
                            <span>Early bird <span class="early-label">(by Mar 20)</span></span>
                            <span class="price">$40</span>
                        </div>
                        <div class="pricing-row">
                            <span>Regular entry</span>
                            <span class="price">$50</span>
                        </div>
                        <div class="pricing-row">
                            <span>Open to</span>
                            <span class="price">All players U1600</span>
                        </div>
                    </div>

                    <div class="pricing-card crown">
                        <div class="section-label">Section</div>
                        <div class="section-name">Crown</div>
                        <div class="prize-amount">$150</div>
                        <div class="prize-label">PRIZE POOL</div>
                        <div class="pricing-row">
                            <span>Early bird <span class="early-label">(by Mar 20)</span></span>
                            <span class="price">$40</span>
                        </div>
                        <div class="pricing-row">
                            <span>Regular entry</span>
                            <span class="price">$50</span>
                        </div>
                        <div class="pricing-row">
                            <span>Open to</span>
                            <span class="price">All players</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tournament Details -->
            <div class="tournament-section">
                <h2>Tournament Details</h2>
                <div class="tournament-details-grid">
                    <div class="tournament-detail-card">
                        <h3>Format</h3>
                        <ul>
                            <li>5 Round Swiss Tournament</li>
                            <li>Time Control: 90 minutes + 30s increment</li>
                            <li>CFC Rated</li>
                            <li>2 Sections: Crown &amp; U1600</li>
                        </ul>
                    </div>
                    <div class="tournament-detail-card">
                        <h3>Schedule</h3>
                        <ul>
                            <li><strong>Saturday, March 28th</strong>
                                <ul>
                                    <li>10:00 AM: Round 1</li>
                                </ul>
                            </li>
                            <li><strong>Sunday, March 29th</strong>
                                <ul>
                                    <li>10:00 AM: Rounds continue</li>
                                </ul>
                            </li>
                        </ul>
                    </div>
                    <div class="tournament-detail-card">
                        <h3>Eligibility</h3>
                        <ul>
                            <li>Open to all players</li>
                            <li>Must have a CFC membership</li>
                            <li>U1600 section: rated under 1600 CFC</li>
                            <li>Crown section: open to all ratings</li>
                        </ul>
                    </div>
                    <div class="tournament-detail-card">
                        <h3>Location</h3>
                        <ul>
                            <li>Stauffer Library</li>
                            <li>101 Union Street</li>
                            <li>Queen's University, Kingston</li>
                            <li>Room 014</li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Contact Section -->
            <div class="tournament-section tournament-contact-section" style="border-bottom: none;">
                <h2>Contact Us</h2>
                <p>Questions or concerns about the tournament? Get in touch:</p>
                <div class="tournament-contact-cards">
                    <div class="tournament-contact-card">
                        <i class="fas fa-envelope"></i>
                        <h3>Email</h3>
                        <p>queenschess@outlook.com</p>
                    </div>
                    <div class="tournament-contact-card">
                        <i class="fab fa-instagram"></i>
                        <h3>Instagram</h3>
                        <p><a href="https://www.instagram.com/queenschessclub/" target="_blank">@queenschessclub</a></p>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <br><br>
    <%- include('footer.ejs'); %>

</body>
</html>
